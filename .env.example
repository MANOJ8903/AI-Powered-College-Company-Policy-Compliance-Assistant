# Google Gemini API Key (Required for vector embeddings & response generation)
# Replace with your actual Gemini API key from Google AI Studio
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# MySQL 8 Database Credentials Configuration
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=policy_guardian
DB_USER=guardian_user
DB_PASSWORD=guardian_pass

# Security Configurations (Required for JWT signature checks)
# Generate a secure 256-bit signing key string
JWT_SECRET=your_jwt_secret_signing_key_must_be_long_and_secure_here_with_at_least_256_bits_for_validation

# ChromaDB Configuration
CHROMADB_URL=http://localhost:8000
